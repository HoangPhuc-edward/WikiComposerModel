{"source": "https://www.youtube.com/watch?v=YgZNTqDDr4U", "content": [{"text": "ừ ừ", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 0.0, "end_seconds": 7.73}}}, {"text": "ừ ừ", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 9.41, "end_seconds": 11.620000000000001}}}, {"text": "ở cuối năm 2019 tại hội nghị thương mại", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 11.96, "end_seconds": 30.2}}}, {"text": "gạo thế giới lần thứ 11 tại Manila", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 28.22, "end_seconds": 33.71}}}, {"text": "Philippines gạo st25 của Việt Nam đã", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 30.2, "end_seconds": 35.54}}}, {"text": "xuất sắc vượt qua gạo của nhiều quốc gia", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 33.71, "end_seconds": 37.85}}}, {"text": "khác khi được chọn là gạo ngon nhất thế", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 35.54, "end_seconds": 40.28}}}, {"text": "giới được vinh danh ở hội nghị quy tụ", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 37.85, "end_seconds": 42.14}}}, {"text": "hơn 20 công ty kinh doanh đạo quốc tế", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 40.28, "end_seconds": 44.449}}}, {"text": "cùng hơn 100 thương gia xuất nhập khẩu", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 42.14, "end_seconds": 47.0}}}, {"text": "gạo và 20 nhà khoa học đến từ 5 châu lục", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 44.449, "end_seconds": 49.339999999999996}}}, {"text": "Đó là một thành công lớn của gạo Việt", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 47.0, "end_seconds": 52.879}}}, {"text": "Nam với thắng lợi này lúa gạo Việt Nam", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 49.34, "end_seconds": 54.559000000000005}}}, {"text": "đã khẳng định được vị thế trên thị", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 52.879, "end_seconds": 57.199}}}, {"text": "trường quốc tế gạo este 25 của Sóc Trăng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 54.559, "end_seconds": 59.48}}}, {"text": "được sản xuất lai tạo từ giống lúa thơm", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 57.199, "end_seconds": 61.489}}}, {"text": "nổi tiếng của vùng đất Sóc Trăng gắn", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 59.48, "end_seconds": 63.589}}}, {"text": "liền tên tuổi của kỹ sư Anh hùng lao", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 61.489, "end_seconds": 66.28999999999999}}}, {"text": "động hồ quanh qua à", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 63.589, "end_seconds": 78.11}}}, {"text": "ở quê hương của kỹ sư Anh hùng lao động", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 66.29, "end_seconds": 80.39}}}, {"text": "của con qua ở Hòa Đông thị xã Vĩnh Châu", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 78.11, "end_seconds": 83.09}}}, {"text": "tỉnh Sóc Trăng tuổi thơ của ông gắn liền", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 80.39, "end_seconds": 85.7}}}, {"text": "với ruộng đồng làng quê sau khi học xong", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 83.09, "end_seconds": 87.68}}}, {"text": "phổ thông ôn thi vào khoa Nông nghiệp", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 85.7, "end_seconds": 91.07000000000001}}}, {"text": "của Trường Đại học Cần Thơ năm 1978 tốt", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 87.68, "end_seconds": 93.32000000000001}}}, {"text": "nghiệp Kỹ sư ngành trồng trọt hổ con cua", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 91.07, "end_seconds": 95.08999999999999}}}, {"text": "trở về quê hương Sóc Trăng và công tác", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 93.32, "end_seconds": 99.22}}}, {"text": "tại phòng Nông nghiệp huyện Mỹ Xuyên năm", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 95.09, "end_seconds": 102.02000000000001}}}, {"text": "1991 kỹ sư hộ con qua tham gia nhóm", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 99.22, "end_seconds": 103.46}}}, {"text": "nghiên cứu của Viện lúa đồng bằng sông", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 102.02, "end_seconds": 106.49}}}, {"text": "Cửu Long và đại học Cần Thơ cũng trong", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 103.46, "end_seconds": 108.44}}}, {"text": "thời gian này ông dần hình thành ý tưởng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 106.49, "end_seconds": 110.63}}}, {"text": "chọn tạo giống lúa thơm đặc sản cho Việt", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 108.44, "end_seconds": 112.61}}}, {"text": "Nam mà trước hết là cho quê hương của", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 110.63, "end_seconds": 116.479}}}, {"text": "mình kẹo thơm ngon Nó có rất nhiều cái", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 112.61, "end_seconds": 118.88}}}, {"text": "đặc tính thì chúng ta tạo ra được cái", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 116.479, "end_seconds": 120.53}}}, {"text": "giống có giá trị cao trên thị trường", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 118.88, "end_seconds": 123.64999999999999}}}, {"text": "quốc tế thì chúng ta muốn làm thì chúng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 120.53, "end_seconds": 126.3}}}, {"text": "ta phải bảo vệ thôi cái phần bảo vệ đó", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 123.65, "end_seconds": 128.729}}}, {"text": "em tự thân doanh nghiệp cũng phải làm từ", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 126.3, "end_seconds": 130.88}}}, {"text": "nhà làm giống phải làm", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 128.729, "end_seconds": 132.89000000000001}}}, {"text": "ở thời gian làm việc trong nhóm nghiên", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 130.88, "end_seconds": 135.26}}}, {"text": "cứu đã tạo điều kiện cho kỹ sư hồ quang", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 132.89, "end_seconds": 137.45}}}, {"text": "cua có điều kiện tìm hiểu nghiên cứu", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 135.26, "end_seconds": 139.82}}}, {"text": "nhiều giống lối đặc sản của Việt Nam Đài", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 137.45, "end_seconds": 142.22}}}, {"text": "Loan và thái lan quá trình Tích lũy kinh", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 139.82, "end_seconds": 143.81}}}, {"text": "nghiệm ông đã đề xuất các phương pháp", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 142.22, "end_seconds": 146.18}}}, {"text": "nghiên cứu cụ thể đó là chọn và lai tạo", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 143.81, "end_seconds": 148.19}}}, {"text": "các giống lúa thơm mới từ những giống", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 146.18, "end_seconds": 150.98000000000002}}}, {"text": "lúa đặc sản của Sóc Trăng từ định hướng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 148.19, "end_seconds": 152.93}}}, {"text": "này nhóm nghiên cứu của ông đã triển", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 150.98, "end_seconds": 155.06}}}, {"text": "khai chọn tạo được 23 giống lúa thơm của", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 152.93, "end_seconds": 159.53}}}, {"text": "Sóc Trăng gọi tắt là SC trong đó có 3", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 155.06, "end_seconds": 161.27}}}, {"text": "giống este được công nhận các giống quốc", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 159.53, "end_seconds": 166.43}}}, {"text": "gia là sp3 sc5 st20 các giống lúa st đã", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 161.27, "end_seconds": 168.38000000000002}}}, {"text": "chinh phục nông dân bằng năng suất lợi", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 166.43, "end_seconds": 170.33}}}, {"text": "nhuận và người tiêu dùng bằng chất lượng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 168.38, "end_seconds": 172.4}}}, {"text": "gạo được thị trường trong nước và nhiều", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 170.33, "end_seconds": 174.38000000000002}}}, {"text": "nước trên thế giới tiêu thụ Mạnh cũng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 172.4, "end_seconds": 176.78}}}, {"text": "bởi vậy Giống lúa st được canh tác hàng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 174.38, "end_seconds": 179.07999999999998}}}, {"text": "chục ngàn hecta trên đồng đất Sóc Trăng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 176.78, "end_seconds": 180.33}}}, {"text": "á", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 179.08, "end_seconds": 182.34}}}, {"text": "chủ đề xuất người nông dân nâng cao giá", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 180.33, "end_seconds": 184.29000000000002}}}, {"text": "trị chất lượng hạt gạo ông qua còn", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 182.34, "end_seconds": 186.0}}}, {"text": "nghiên cứu đưa chế phẩm sinh học và quy", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 184.29, "end_seconds": 188.48999999999998}}}, {"text": "trình sản xuất lúa thơm st với phương", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 186.0, "end_seconds": 190.26}}}, {"text": "pháp canh tác này sản phẩm không chỉ", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 188.49, "end_seconds": 192.33}}}, {"text": "ngon mà còn an toàn cho người tiêu dùng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 190.26, "end_seconds": 195.14999999999998}}}, {"text": "thân thiện với môi trường tương ứng dụng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 192.33, "end_seconds": 197.01000000000002}}}, {"text": "khoa học công nghệ giúp Sóc Trăng dần", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 195.15, "end_seconds": 198.69}}}, {"text": "trở thành một trong những chỉ dẫn địa lý", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 197.01, "end_seconds": 201.03}}}, {"text": "hấp dẫn về lúa thơm trong cả nước vươn", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 198.69, "end_seconds": 203.04}}}, {"text": "lên đứng top đầu những tình sản xuất lúa", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 201.03, "end_seconds": 204.33}}}, {"text": "lớn nhất trong khu vực Đồng bằng sông", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 203.04, "end_seconds": 206.67}}}, {"text": "Cửu Long giúp hàng ngàn hộ dân thoát", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 204.33, "end_seconds": 215.01000000000002}}}, {"text": "nghèo của kỹ sư Hồ Văn qua thì đến thời", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 206.67, "end_seconds": 219.02999999999997}}}, {"text": "điểm này và đưa năng suất mà lợi nhuận", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 215.01, "end_seconds": 222.23999999999998}}}, {"text": "đạt hiệu quả kinh tế cao đây nhằm qua", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 219.03, "end_seconds": 225.75}}}, {"text": "như là góp phần xóa đói giảm nghèo cứ", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 222.24, "end_seconds": 228.84}}}, {"text": "năm 2013 sau khi nghỉ hưu toàn bộ thời", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 225.75, "end_seconds": 231.09}}}, {"text": "gian ông đều ở khu thí nghiệm nông trại", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 228.84, "end_seconds": 233.22}}}, {"text": "chọn giống thuộc thị trấn Mỹ Xuyên huyện", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 231.09, "end_seconds": 235.86}}}, {"text": "Mỹ Xuyên tỉnh Sóc Trăng với sự tâm huyết", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 233.22, "end_seconds": 238.32}}}, {"text": "của ông nơi đây cũng là địa chỉ quen", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 235.86, "end_seconds": 240.34}}}, {"text": "thuộc thu hút các doanh nghiệp và cá", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 238.32, "end_seconds": 242.98}}}, {"text": "khoa học Nông nghiệp tỉnh tham quan cộng", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 240.34, "end_seconds": 245.739}}}, {"text": "tác nghiên cứu chọn tạo giống lúa 40 năm", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 242.98, "end_seconds": 248.01899999999998}}}, {"text": "đó là cuộc đời rất là dài trong các", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 245.739, "end_seconds": 250.47}}}, {"text": "nghiên cứu Cái đó có sự đóng góp của anh", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 248.019, "end_seconds": 253.45000000000002}}}, {"text": "mặc dù là dài như thế tuổi của anh đã", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 250.47, "end_seconds": 258.66}}}, {"text": "cao đến nay là đã 68 tuổi rồi nhưng mà", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 253.45, "end_seconds": 261.549}}}, {"text": "thủ càng cao nhưng mà cái khu ruộng động", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 258.66, "end_seconds": 263.77000000000004}}}, {"text": "của anh nghiên cứu càng ngày nó càng to", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 261.549, "end_seconds": 266.5}}}, {"text": "cứ mỗi lần mà đi vào xem thì nó có những", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 263.77, "end_seconds": 269.46}}}, {"text": "cái là nó nó nó nó thay đổi liên tục", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 266.5, "end_seconds": 272.65}}}, {"text": "trong lúa st25 được nghiên cứu từ cách", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 269.46, "end_seconds": 276.09999999999997}}}, {"text": "đây hơn 20 năm năm 2014 giống lúa thơm", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 272.65, "end_seconds": 278.73999999999995}}}, {"text": "được đưa vào khảo nghiệm và đến năm 2016", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 276.1, "end_seconds": 281.65000000000003}}}, {"text": "bắt đầu Trồng thử đây là giống lúa ngắn", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 278.74, "end_seconds": 284.35}}}, {"text": "ngày có tính chống chịu hạn mặn và sâu", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 281.65, "end_seconds": 286.57}}}, {"text": "bệnh hơn hẳn một số giống lúa khác và", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 284.35, "end_seconds": 288.63}}}, {"text": "cho sản lượng đạt tới 7 tấn của hecta", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 286.57, "end_seconds": 291.82}}}, {"text": "ngoài là giọng nói đặc sản st25 còn là", "metadata": {"source_type": "youtube", "locator": {"start_seconds": 288.63, "end_seconds": 293.35}}}, {"text": "giống lúa thích 